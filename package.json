{
  "name": "codex-multi-login",
  "displayName": "Codex Multi Login",
  "description": "Lightweight VS Code extension for managing multiple Codex accounts, switching auth.json, and checking quota.",
  "version": "1.0.2",
  "publisher": "jyc8369",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jyc8369/codex_multi_login.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "files": [
    "extension/out/**",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "contributes": {
    "commands": [
      { "command": "codexMultiLogin.openDashboard", "title": "Codex Multi Login: Open Dashboard" },
      { "command": "codexMultiLogin.addAccount", "title": "Codex Multi Login: Add Account via OAuth" },
      { "command": "codexMultiLogin.importCurrentAuth", "title": "Codex Multi Login: Import Current auth.json" },
      { "command": "codexMultiLogin.switchAccount", "title": "Codex Multi Login: Switch Account" },
      { "command": "codexMultiLogin.refreshQuota", "title": "Codex Multi Login: Refresh Quota" },
      { "command": "codexMultiLogin.refreshAllQuotas", "title": "Codex Multi Login: Refresh All Quotas" }
    ],
    "configuration": {
      "title": "Codex Multi Login",
      "properties": {
        "codexMultiLogin.dashboardTheme": {
          "type": "string",
          "enum": ["auto", "vscode", "dark", "light"],
          "default": "auto",
          "markdownDescription": "Dashboard theme. Use VS Code to sync with the current editor theme."
        },
        "codexMultiLogin.dashboardLocale": {
          "type": "string",
          "enum": ["en", "ko"],
          "default": "en",
          "markdownDescription": "Dashboard language."
        },
        "codexMultiLogin.storageMode": {
          "type": "string",
          "enum": ["keychain", "plaintext"],
          "default": "keychain",
          "markdownDescription": "Token storage mode. Keychain is recommended."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p . && npm run copy:webview",
    "copy:webview": "node scripts/copy-webview.mjs",
    "watch": "tsc -watch -p .",
    "test": "echo \"No tests yet\"",
    "lint": "tsc -p . --noEmit",
    "package": "bash extension/package.sh"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.8.3",
    "@vscode/vsce": "^3.7.0"
  },
  "dependencies": {}
}
