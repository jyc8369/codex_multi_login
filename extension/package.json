{
  "name": "codex-multi-login",
  "displayName": "Codex Multi Login",
  "description": "Lightweight VS Code extension for managing multiple Codex accounts, switching auth.json, and checking quota.",
  "version": "1.0.6",
  "publisher": "jyc8369",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jyc8369/codex_multi_login.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": ["Other"],
  "icon": "icon.png",
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "browser": "./out/browser/extension.js",
  "files": [
    "out/**",
    "icon.png",
    "README.md",
    "STORAGE.md",
    "JSON_FORMAT.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile-web",
    "compile-web": "bash ../package.sh --build-only",
    "package-web": "bash ../package.sh --package",
    "publish-web": "bash ../package.sh --publish"
  },
  "contributes": {
    "commands": [
      { "command": "codexMultiLogin.openDashboard", "title": "Codex Multi Login: Open Dashboard" },
      { "command": "codexMultiLogin.addAccount", "title": "Codex Multi Login: Add Account via OAuth" },
      { "command": "codexMultiLogin.importJson", "title": "Codex Multi Login: Import / Export JSON" },
      { "command": "codexMultiLogin.switchAccount", "title": "Codex Multi Login: Switch Account" },
      { "command": "codexMultiLogin.deleteAccount", "title": "Codex Multi Login: Delete Account" },
      { "command": "codexMultiLogin.refreshQuota", "title": "Codex Multi Login: Refresh Quota" },
      { "command": "codexMultiLogin.refreshAllQuotas", "title": "Codex Multi Login: Refresh All Quotas" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "codexMultiLogin.openDashboard", "when": "true" },
        { "command": "codexMultiLogin.addAccount", "when": "!isWeb" },
        { "command": "codexMultiLogin.importJson", "when": "!isWeb" },
        { "command": "codexMultiLogin.switchAccount", "when": "!isWeb" },
        { "command": "codexMultiLogin.deleteAccount", "when": "!isWeb" },
        { "command": "codexMultiLogin.refreshQuota", "when": "!isWeb" },
        { "command": "codexMultiLogin.refreshAllQuotas", "when": "!isWeb" }
      ]
    },
    "configuration": {
      "title": "Codex Multi Login",
      "properties": {
        "codexMultiLogin.dashboardTheme": {
          "type": "string",
          "enum": ["auto", "vscode", "dark", "light"],
          "default": "auto",
          "markdownDescription": "Dashboard theme. Use VS Code to sync with the current editor theme."
        },
        "codexMultiLogin.dashboardLocale": {
          "type": "string",
          "enum": ["en", "ko"],
          "default": "en",
          "markdownDescription": "Dashboard language."
        }
      }
    }
  }
}
